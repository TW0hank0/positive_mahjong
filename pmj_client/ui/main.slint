import { Button, LineEdit } from "std-widgets.slint";
import {
    MaterialText,
    ScrollView,
    OutlineButton,
    MaterialPalette,
} from "../material/material.slint";

/// Noto Sans TC
import "../../../assets/Noto_Sans_TC/static/NotoSansTC-Regular.ttf";

/// Material Symbols Outlined
import "../../../assets/material_symbols/MaterialSymbolsOutlined[FILL,GRAD,opsz,wght].ttf";

export { MaterialWindowAdapter } from "../material/material.slint";

export enum Scenes {
    HomePage,
    GamePlayBase,
    GamePlayV1Simple,
}

component HomePage inherits ScrollView {
    in-out property <string> server_response_text: "";
    in-out property <string> server_ip: "";
    in-out property <string> project-version: "unknown-version";
    callback add_player();

    ScrollView {
        width: 100%;
        height: 100%;
        horizontal_scrollbar_policy: ScrollBarPolicy.as-needed;
        vertical_scrollbar_policy: ScrollBarPolicy.as-needed;

        VerticalLayout {
            width: 100%;
            height: 100%;
            alignment: LayoutAlignment.start;

            Rectangle {
                height: 14px;
            }

            HorizontalLayout {
                alignment: LayoutAlignment.start;
                MaterialText {
                    text: "PMJ Client";
                    font-size: 30px;
                    horizontal-alignment: TextHorizontalAlignment.left;
                    vertical-alignment: TextVerticalAlignment.bottom;
                }

                Rectangle {
                    width: 10px;
                }

                MaterialText {
                    text: root.project-version;
                    font-size: 18px;
                    vertical-alignment: TextVerticalAlignment.bottom;
                }
            }

            Rectangle {
                height: 15px;
            }

            HorizontalLayout {
                alignment: LayoutAlignment.start;
                //height: 60px;

                Rectangle {
                    border-radius: 22px;
                    background: MaterialPalette.primary;
                    width: 160px;
                    MaterialText {
                        text: "Base模式";
                        color: MaterialPalette.on_primary;
                        font-size: 20px;
                    }
                }

                Rectangle {
                    width: 3%;
                }

                MaterialText {
                    text: "伺服器Ip：";
                    font-size: 24px;
                    width: 130px;
                }

                MaterialText {
                    text: "ws://";
                    color: Colors.gray;
                    font-size: 22px;
                    width: 65px;
                }

                Rectangle {
                    width: 5px;
                }

                LineEdit {
                    text <=> root.server_ip;
                    min-height: 30px;
                    max-height: 150px;
                    width: 60%;
                }

                Rectangle {
                    width: 15px;
                }

                OutlineButton {
                    text: "加入遊戲";
                    clicked => {
                        root.add_player();
                    }
                    width: 160px;
                }
            }

            Rectangle {
                height: 15px;
            }

            Rectangle {
                background: MaterialPalette.secondary_container;
                border-radius: 15px;
                min-height: 700px;
                min-width: 200px;

                ScrollView {
                    vertical-scrollbar-policy: ScrollBarPolicy.as-needed;
                    horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;
                    width: 100%;
                    height: 100%;
                    VerticalLayout {
                        alignment: LayoutAlignment.start;
                        width: 100%;
                        height: 100%;

                        HorizontalLayout {
                            alignment: LayoutAlignment.start;
                            width: 100%;
                            height: 100%;

                            MaterialText {
                                text: "Client Log:\n" + root.server_response_text;
                                horizontal-alignment: TextHorizontalAlignment.left;
                                vertical-alignment: TextVerticalAlignment.top;
                                //wrap: TextWrap.char-wrap;
                                font-size: 18px;
                                width: 90%;
                                height: 90%;
                                color: MaterialPalette.on_secondary_container;
                            }
                        }
                    }
                }
            }
        }
    }
}

component GamePlayBase inherits ScrollView {
    in-out property <int> player_id: 0;
    in-out property <bool> is-game-start: false;

    horizontal_scrollbar_policy: ScrollBarPolicy.as-needed;
    vertical_scrollbar_policy: ScrollBarPolicy.as-needed;
    VerticalLayout {
        Rectangle {
            background: MaterialPalette.surface;

            HorizontalLayout {
                MaterialText {
                    text: "玩家id：" + root.player_id;
                    font-size: 14px;
                }

                Rectangle {
                    width: 20%;
                }

                MaterialText {
                    text: is-game-start ? "遊戲已開始" : "遊戲準備中";
                    font-size: 14px;
                }
            }
        }
    }
}

component GamePlayV1Simple inherits ScrollView {
    in-out property <string> server_ip: "unknown";

    horizontal_scrollbar_policy: ScrollBarPolicy.as-needed;
    vertical_scrollbar_policy: ScrollBarPolicy.as-needed;
    VerticalLayout {
        HorizontalLayout {
            Rectangle {
                width: 75%;
            }

            MaterialText {
                text: "伺服器Ip：" + root.server_ip;
                font-size: 14px;
            }
        }
    }
}

export component MainWindow inherits Window {
    title: "PositiveMahjong Client";
    min-width: 1080px;
    min-height: 720px;
    default-font-size: 20px;
    default-font-family: "Noto Sans TC";
    // == Var ==
    // HomePage
    in-out property <string> home_page_server_ip/*  <=> scene_home_page.server_ip */;
    in-out property <string> home_page_server_response_text/*  <=> scene_home_page.server_response_text */;
    in-out property <string> home-page-project-version;
    // GamePlayV1Simple
    in-out property <string> game_play_v1_simple_server_ip/*  <=> scene_game_play_v1_simple.server_ip */;
    // GamePlayBase
    in-out property <int> game-play-base-player-id;
    // MainWindow / Other
    in-out property <Scenes> current-scene: Scenes.HomePage;
    in-out property <bool> is-changing-scene: false;
    // == CallBack ==
    // HomePage
    callback home_page_add_player/*  <=> scene_home_page.test_connection */;

    ScrollView {
        horizontal_scrollbar_policy: ScrollBarPolicy.as-needed;
        vertical_scrollbar_policy: ScrollBarPolicy.as-needed;
        //
        if current-scene == Scenes.HomePage: scene_home_page := HomePage {
            server_ip <=> home_page_server_ip;
            server_response_text <=> home_page_server_response_text;
            project-version <=> home-page-project-version;
            add_player => home_page_add_player();
        }

        if current-scene == Scenes.GamePlayV1Simple: scene_game_play_v1_simple := GamePlayV1Simple {
            //opacity: 0.0;
            server_ip <=> game_play_v1_simple_server_ip;
        }

        if current-scene == Scenes.GamePlayBase: scene_game_play_base := GamePlayBase {
            player_id <=> game-play-base-player-id;
        }
    }

    /*states [
        active when current-scene == Scenes.HomePage: {
            scene_home_page.opacity: 1.0;
            scene_home_page.enabled: true;
        }
        active when current-scene == Scenes.GamePlayV1Simple: {
            scene_game_play_v1_simple.opacity: 1.0;
            scene_game_play_v1_simple.enabled: true;
        }
        active when current-scene == Scenes.GamePlayBase : {
            scene_game_play_base.opacity: 1.0;
            scene_game_play_base.enabled: true;
        }
        active when is-changing-scene: {
            scene_home_page.opacity: 0.0;
            scene_home_page.enabled: false;
            scene_game_play_v1_simple.opacity: 0.0;
            scene_game_play_v1_simple.enabled: false;
        }
    ]*/
}
